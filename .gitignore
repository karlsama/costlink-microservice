# ============================================================
# CostLink .gitignore
# ============================================================

# === 环境变量 ===
.env

# === Java / Maven ===
target/
*.class
*.jar
*.war
!.mvn/wrapper/maven-wrapper.jar

# === IDE ===
.idea/
*.iml
.vscode/
.settings/
.project
.classpath
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db

# === Node (前端) ===
node_modules/
dist/
*.log
npm-debug.log*

# === Docker ===
# Dockerfile 和 docker-compose.yml 要提交
# 但构建产物不提交

# === 临时文件 ===
*.tmp
*.bak
/logs/
