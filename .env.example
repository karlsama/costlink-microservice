# ============================================================
# CostLink .env.example — 环境变量模板（提交到 Git 供参考）
# 使用: 复制为 .env 后填入真实值
# ============================================================

# Nacos Namespace ID（从 Nacos 控制台「命名空间」页面获取）
NACOS_NAMESPACE=填入你的Namespace_ID

# MySQL
DB_USERNAME=root
DB_PASSWORD=填入你的数据库密码

# Redis
REDIS_PASSWORD=填入你的Redis密码（无密码则留空）

# RabbitMQ
RABBITMQ_USERNAME=costlink
RABBITMQ_PASSWORD=填入你的RabbitMQ密码

# JWT 签名密钥（生产环境换强密码）
JWT_SECRET=填入一个至少32位的随机字符串

# 百度 OCR（从百度智能云控制台获取）
BAIDU_OCR_APP_ID=填入你的AppId
BAIDU_OCR_API_KEY=填入你的ApiKey
BAIDU_OCR_SECRET_KEY=填入你的SecretKey
